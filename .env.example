# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/realtime_tracker
SESSION_SECRET=change-me-to-a-random-64-char-string

# ── Optional ──────────────────────────────────────────────────────────────────
# ADMIN_EMAIL=admin@example.com          # First user with this email gets admin role
# PORT=3000                               # Default: 3000 (Render injects this automatically)
# NODE_ENV=production                     # Set to 'production' on Render/deploy

# Comma-separated list of allowed CORS origins (required in production)
# CORS_ALLOWED_ORIGINS=https://your-app.onrender.com

# ── Frontend ──────────────────────────────────────────────────────────────────
# VITE_API_URL=https://your-server.com    # Required for Capacitor native builds; use origin only (no trailing slash/path)

# ── Local dev only ────────────────────────────────────────────────────────────
# FRONTEND_DIR=../frontend/dist           # Path to built frontend (set automatically in Docker)
# MONITORING_PORT=9090                    # Port for /metrics and /health (internal only)
