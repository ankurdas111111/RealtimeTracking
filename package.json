{
  "name": "kinnect",
  "version": "1.0.0",
  "description": "Real-time GPS location tracking with rooms, contacts, SOS, geofencing, and live sharing",
  "scripts": {
    "start": "npm run build:frontend && cd backend && go build -o server . && ./server",
    "build": "VITE_TARGET=web npm run build:frontend",
    "build:frontend": "cd frontend && npx vite build",
    "dev:fe": "cd frontend && npx vite",
    "dev:be": "cd backend && if [ -f ../.env ]; then set -a; . ../.env; set +a; fi; PORT=${PORT:-3001} go run .",
    "build:backend": "cd backend && go build -o kinnect-server .",
    "dev": "node scripts/start-v3.js",
    "test": "cd backend && ./test/integration_test.sh 3001",
    "bench": "bash backend/test/benchmark-unified.sh 3001 10 20 250",
    "build:android": "cd frontend && VITE_TARGET=capacitor VITE_REALTIME_PROTOCOL=ws npx vite build && npx cap sync android",
    "build:android:prod": "node scripts/build-mobile-with-api.cjs android",
    "run:android": "cd frontend && npx cap run android",
    "apk:release": "cd frontend/android && ./gradlew clean assembleRelease",
    "aab:release": "cd frontend/android && ./gradlew clean bundleRelease",
    "build:ios": "cd frontend && VITE_TARGET=capacitor VITE_REALTIME_PROTOCOL=ws npx vite build && npx cap sync ios",
    "build:ios:prod": "node scripts/build-mobile-with-api.cjs ios",
    "run:ios": "cd frontend && npx cap run ios"
  },
  "keywords": [
    "realtime",
    "tracking",
    "gps",
    "socket.io",
    "maplibre-gl"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/geolocation": "^8.1.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.17.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "maplibre-gl": "^5.20.1",
    "pg": "^8.18.0",
    "pino": "^9.14.0",
    "prom-client": "^15.1.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3",
    "socket.io-msgpack-parser": "^3.0.2",
    "svelte": "^5.51.2",
    "svelte-spa-router": "^4.0.1",
    "vite": "^6.4.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "terser": "^5.31.0",
    "ws": "^8.19.0"
  }
}
